<Window x:Class="SaveOClock.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Save-O-Clock Settings" 
        Height="550" Width="650"
        Icon="/src/assets/save-o-clock.ico"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        FontFamily="Segoe UI Variable Display, Segoe UI, Sans-Serif">
    
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" GlassFrameThickness="-1" CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Border x:Name="RootBorder" CornerRadius="0" BorderThickness="1" BorderBrush="#33000000" Background="#F3F3F3">
        <Grid>
            <!-- Main Content -->
            <Grid Margin="32,48,32,32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Screensaver Settings" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,24"/>

                <StackPanel Grid.Row="1">
                    <TextBlock Text="Content Source" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    
                    <Border Background="White" CornerRadius="4" Padding="16" BorderThickness="1" BorderBrush="#15000000">
                        <StackPanel>
                            <TextBlock Text="HTML File" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Text="The web page to display as your screensaver." Foreground="#666666" FontSize="12" Margin="0,0,0,12"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="PathTextBox" Padding="8,6" VerticalAlignment="Center" BorderThickness="1" BorderBrush="#33000000"/>
                                <Button Grid.Column="1" Content="Browse" Margin="8,0,0,0" Padding="16,4" Click="BrowseButton_Click" Background="#FFFFFF" BorderThickness="1" BorderBrush="#33000000"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Rendering" FontSize="14" FontWeight="SemiBold" Margin="0,24,0,12"/>
                    <Border Background="White" CornerRadius="4" Padding="16" BorderThickness="1" BorderBrush="#15000000">
                         <Grid>
                            <StackPanel>
                                <TextBlock Text="Engine" FontWeight="SemiBold"/>
                                <TextBlock Text="Chromium (WebView2) Evergreen" Foreground="#666666" FontSize="12"/>
                            </StackPanel>
                            <TextBlock Text="" FontFamily="Segoe MDL2 Assets" Foreground="#666666" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="16"/>
                         </Grid>
                    </Border>
                </StackPanel>

                <!-- Footer Operations -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                    <Button Content="Save" Width="80" Height="32" Click="SaveButton_Click" Background="#005FB8" Foreground="White" BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button Content="Cancel" Width="80" Height="32" Margin="8,0,0,0" Click="CancelButton_Click" Background="Transparent" BorderThickness="1" BorderBrush="#33000000">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
            
            <!-- Controls Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,8,0">
                <Button Content="" FontFamily="Segoe MDL2 Assets" 
                        Background="Transparent" BorderThickness="0" Foreground="#333333" Width="36" Height="32" Click="HelpButton_Click"
                        ToolTip="View on GitHub"
                        WindowChrome.IsHitTestVisibleInChrome="True"/>
                <Button Content="" FontFamily="Segoe MDL2 Assets" 
                        Background="Transparent" BorderThickness="0" Foreground="#333333" Width="36" Height="32" Click="CancelButton_Click"
                        WindowChrome.IsHitTestVisibleInChrome="True"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
